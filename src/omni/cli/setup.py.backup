                "temperature_range": [0.0, 2.0],
                "supports_tools": True,
            }

            # Add cost config
            if "pro" in model:
                self.new_config["cost_config"]["rates"][model] = {
                    "input": 3.50,
                    "output": 10.50,
                }
            elif "flash" in model:
                self.new_config["cost_config"]["rates"][model] = {
                    "input": 0.075,
                    "output": 0.30,
                }

        self.configured_providers.append("Google AI")
        self.configured_models.extend(models)

    def _configure_deepseek(self, api_key: str, models: List[str]) -> None:
        """Configure DeepSeek in the new config."""
