            if "DEEPSEEK_API_KEY" in os.environ and api_key == os.environ["DEEPSEEK_API_KEY"]:
                del os.environ["DEEPSEEK_API_KEY"]

    def _configure_openai(self, api_key: str, models: List[str]) -> None:
        """Configure OpenAI in the new config."""
        self.new_config["api_keys"]["OPENAI_API_KEY"] = api_key
        self.new_config["provider_configs"]["openai"] = {
            "base_url": "https://api.openai.com/v1",
        }

        # Add OpenAI provider if not exists
        if "openai" not in self.new_config["providers"]:
            self.new_config["providers"]["openai"] = {
                "type": "litellm",
                "description": "OpenAI models via LiteLLM",
                "enabled": True,
                "config": {},
                "models": {},
            }

        # Add models
        for model in models:
            model_name = model.replace("openai/", "")
            self.new_config["providers"]["openai"]["models"][model] = {
                "max_tokens": 8192,
                "temperature_range": [0.0, 2.0],
                "supports_functions": True,
                "supports_tools": True,
            }

            # Add cost config
            if "gpt-4" in model:
                self.new_config["cost_config"]["rates"][model] = {
                    "input": 30.00,
                    "output": 60.00,
                }
            elif "gpt-3.5" in model:
                self.new_config["cost_config"]["rates"][model] = {
                    "input": 0.50,
                    "output": 1.50,
                }
            else:
                # Default cost for other OpenAI models
                self.new_config["cost_config"]["rates"][model] = {
                    "input": 10.00,
                    "output": 30.00,
                }

        self.configured_providers.append("OpenAI")
        self.configured_models.extend(models)

    def _configure_anthropic(self, api_key: str, models: List[str]) -> None:
        """Configure Anthropic in the new config."""
        self.new_config["api_keys"]["ANTHROPIC_API_KEY"] = api_key
        self.new_config["provider_configs"]["anthropic"] = {
            "base_url": "https://api.anthropic.com",
            "version": "2023-06-01",
        }

        # Add Anthropic provider if not exists
        if "anthropic" not in self.new_config["providers"]:
            self.new_config["providers"]["anthropic"] = {
                "type": "litellm",
                "description": "Anthropic Claude models via LiteLLM",
                "enabled": True,
                "config": {},
                "models": {},
            }

        # Add models
        for model in models:
            model_name = model.replace("anthropic/", "")
            self.new_config["providers"]["anthropic"]["models"][model] = {
                "max_tokens": 200000,
                "temperature_range": [0.0, 1.0],
                "supports_tools": True,
            }

            # Add cost config
            if "opus" in model:
                self.new_config["cost_config"]["rates"][model] = {
                    "input": 15.00,
                    "output": 75.00,
                }
            elif "sonnet" in model:
                self.new_config["cost_config"]["rates"][model] = {
                    "input": 3.00,
                    "output": 15.00,
                }
            elif "haiku" in model:
                self.new_config["cost_config"]["rates"][model] = {
                    "input": 0.25,
                    "output": 1.25,
                }

        self.configured_providers.append("Anthropic")
        self.configured_models.extend(models)

    def _configure_google(self, api_key: str, models: List[str]) -> None:
        """Configure Google AI in the new config."""
        self.new_config["api_keys"]["GOOGLE_API_KEY"] = api_key
        self.new_config["provider_configs"]["google"] = {
